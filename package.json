    "@tanstack/router-devtools": "^1.141.2",
    "bcryptjs": "^3.0.3",
    "drizzle-orm": "^0.45.2",
    "framer-motion": "^12.23.26",
    "pnpm": "^10.25.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-error-boundary": "^6.0.0",
    "react-howler": "^5.2.0",
    "react-icons": "^5.5.0",
    "react-intersection-observer": "^10.0.0",
